{
	"useTabs": true,
	"tabWidth": 4,
	"singleQuote": true,
	"trailingComma": "none",
	"printWidth": 120,
	"plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
	"overrides": [
		{
			"files": ["*.md"],
			"options": {
				"tabWidth": 2,
				"printWidth": 500,
				"embeddedLanguageFormatting": "off",
				"plugins": []
			}
		}
	]
}
